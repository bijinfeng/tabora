{
  "name": "tabora",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "vp config",
    "dev": "vp dev apps/playground",
    "staged": "vp staged",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --config vite.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "build": "vp run -r build",
    "pack": "vp run -r build",
    "lint": "vp lint --type-aware --type-check",
    "lint:fix": "vp lint --type-aware --type-check --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "check:fix": "vp check --fix"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:build",
    "@testing-library/jest-dom": "^6.9.1",
    "@tsdown/css": "0.22.0",
    "@types/node": "^25.9.1",
    "@vitest/browser-playwright": "catalog:test",
    "fake-indexeddb": "catalog:test",
    "happy-dom": "catalog:test",
    "playwright": "catalog:test",
    "tailwindcss": "catalog:build",
    "tsdown": "catalog:build",
    "typescript": "catalog:build",
    "vite": "catalog:build",
    "vite-plugin-solid": "catalog:build",
    "vite-plus": "catalog:build",
    "vitest": "catalog:test"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.3.0"
}
