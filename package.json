{
  "name": "tabora",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "vp config",
    "dev": "vp dev apps/playground",
    "dev:directus": "pnpm --dir backend/directus dev",
    "dev:directus:stack": "docker compose -f infra/docker/compose.directus.yml up -d",
    "staged": "vp staged",
    "test": "pnpm run test:unit",
    "test:directus": "pnpm --dir backend/directus test",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "build": "vp run -r build",
    "pack": "vp run -r build",
    "lint": "vp lint --type-aware --type-check",
    "lint:fix": "vp lint --type-aware --type-check --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check && pnpm check:architecture",
    "check:fix": "vp check --fix",
    "check:architecture": "node scripts/check-architecture.mjs",
    "directus:bootstrap": "pnpm --dir backend/directus bootstrap",
    "directus:schema:provision": "pnpm --dir backend/directus schema:provision",
    "quality": "node scripts/quality-report.mjs",
    "regression:summary": "node scripts/regression-summary.mjs"
  },
  "dependencies": {
    "geist": "^1.7.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:build",
    "@testing-library/jest-dom": "^6.9.1",
    "@tsdown/css": "0.22.0",
    "@types/node": "catalog:node",
    "@vitest/browser-playwright": "catalog:test",
    "fake-indexeddb": "catalog:test",
    "happy-dom": "catalog:test",
    "playwright": "catalog:test",
    "tailwindcss": "catalog:build",
    "tsdown": "catalog:build",
    "tsx": "^4.19.2",
    "typescript": "catalog:build",
    "vite": "catalog:build",
    "vite-plugin-solid": "catalog:build",
    "vite-plus": "catalog:build",
    "vitest": "catalog:test"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.2"
}
