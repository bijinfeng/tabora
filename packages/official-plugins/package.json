{
  "name": "@tabora/official-plugins",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./plugin-manager-entry.css": "./src/plugin-manager-entry.css",
    "./settings-workspace.css": "./src/settings-workspace.css",
