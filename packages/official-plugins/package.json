{
  "name": "@tabora/official-plugins",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./styles.css": "./src/styles.css"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json",
      "./styles.css": "./dist/styles.css"
    }
  },
  "scripts": {
    "build": "vp pack src/index.ts",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@stylexjs/stylex": "catalog:style",
    "@tabora/layout-dashboard": "workspace:*",
    "@tabora/orchestrator": "workspace:*",
    "@tabora/platform-kernel": "workspace:*",
    "@tabora/plugin-api": "workspace:*",
    "@tabora/plugin-notes": "workspace:*",
    "@tabora/plugin-quick-links": "workspace:*",
    "@tabora/plugin-todo": "workspace:*",
    "@tabora/plugin-weather": "workspace:*",
    "@tabora/ui": "workspace:*",
    "solid-js": "catalog:ui"
  },
  "devDependencies": {
    "@tabora/tsconfig": "workspace:*",
    "vite-plugin-solid": "catalog:build"
  }
}
