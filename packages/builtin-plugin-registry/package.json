{
  "name": "@tabora/builtin-plugin-registry",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "vp pack src/index.ts",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@tabora/layout-dashboard": "workspace:*",
    "@tabora/layout-diy-masonry": "workspace:*",
    "@tabora/official-plugins": "workspace:*",
    "@tabora/platform-kernel": "workspace:*",
    "@tabora/plugin-notes": "workspace:*",
    "@tabora/plugin-quick-links": "workspace:*",
    "@tabora/plugin-todo": "workspace:*",
    "@tabora/plugin-weather": "workspace:*"
  },
  "devDependencies": {
    "@tabora/tsconfig": "workspace:*"
  }
}
