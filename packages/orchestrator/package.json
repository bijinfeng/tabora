{
  "name": "@tabora/orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "vp pack src/index.ts",
    "test": "vitest run --root ../.. packages/orchestrator/src/plugin-catalog.test.ts packages/orchestrator/src/layout-engine.test.ts packages/orchestrator/src/layout-package-boundaries.test.ts packages/orchestrator/src/plugin-boundary.test.ts packages/orchestrator/src/settings-navigator.test.ts packages/orchestrator/src/command-palette-model.test.ts packages/orchestrator/src/command-catalog.test.ts packages/orchestrator/src/shortcut-registry.test.ts packages/orchestrator/src/context-menu-model.test.ts packages/orchestrator/src/layout-switcher.test.ts packages/orchestrator/src/drag-sort-model.test.ts packages/orchestrator/src/workspace-preset.test.ts"
  },
  "dependencies": {
    "@tabora/platform-kernel": "workspace:*",
    "@tabora/plugin-api": "workspace:*",
    "@tabora/storage": "workspace:*",
    "solid-js": "catalog:ui"
  },
  "devDependencies": {
    "@tabora/tsconfig": "workspace:*"
