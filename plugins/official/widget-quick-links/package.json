{
  "name": "@tabora/plugin-quick-links",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./styles.css": "./dist/styles.css",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "node ../../../scripts/build-stylex-package.mjs --package . --entry src/index.ts --css-name styles.css",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@stylexjs/stylex": "catalog:style",
    "@tabora/platform-kernel": "workspace:*",
    "@tabora/plugin-api": "workspace:*",
    "@tabora/ui": "workspace:*",
    "lucide-solid": "catalog:ui",
    "solid-js": "catalog:ui"
  },
  "devDependencies": {
    "@tabora/tsconfig": "workspace:*"
  }
}
