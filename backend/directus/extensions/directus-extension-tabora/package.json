{
  "name": "directus-extension-tabora",
  "version": "1.0.0",
  "private": true,
  "description": "Tabora endpoints for authentication, sessions, and attachments",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-extension-endpoint"
  ],
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "typecheck": "tsc --noEmit",
    "validate": "directus-extension validate"
  },
  "dependencies": {
    "@directus/errors": "2.4.0",
    "zod": "catalog:data"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "18.0.1",
    "@directus/types": "^16.0.0",
    "@tabora/tsconfig": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/node": "catalog:node",
    "typescript": "catalog:build"
  },
  "icon": "extension",
  "directus:extension": {
    "type": "endpoint",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^12.1.1"
  }
}
