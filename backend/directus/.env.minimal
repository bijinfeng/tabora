# Directus 最小化配置（仅 Postgres + Directus，无 Redis/MinIO/Nginx）

KEY=replace-me-with-random-key
SECRET=replace-me-with-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me

# Database
DB_CLIENT=pg
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=tabora_directus
DB_USER=tabora
DB_PASSWORD=tabora

# Public URL（改为你的域名或服务器 IP）
PUBLIC_URL=http://your-server-ip:8055

# 存储（使用本地文件系统，不用 S3）
STORAGE_LOCATIONS=local
